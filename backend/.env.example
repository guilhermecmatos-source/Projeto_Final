PORT=3001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=fleet_db

# Ou use URL única:
# DATABASE_URL=mysql://root:sua_senha@localhost:3306/fleet_db

JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development

# Geocoding / rotas (ordem de fallback: google,qualp,mapeia,heuristic)
GEO_PROVIDER_ORDER=google,qualp,mapeia,heuristic
GOOGLE_MAPS_API_KEY=
QUALP_API_KEY=
QUALP_API_URL=https://api.qualp.com.br
MAPEIA_API_KEY=
MAPEIA_API_URL=https://api.mapeia.com.br
