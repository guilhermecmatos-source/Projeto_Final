# API via proxy Next.js (/api → backend). Funciona no celular na mesma rede Wi‑Fi.
NEXT_PUBLIC_API_URL=/api

# Docker: URL interna do backend para rewrites (não altere no celular)
# BACKEND_URL=http://backend:3001

# Local sem Docker: proxy aponta para o backend local
# BACKEND_URL=http://127.0.0.1:3001

# Evite usar localhost:3001 no celular — no telefone "localhost" é o próprio aparelho.
# Acesse pelo IP do PC, ex.: http://192.168.1.10:3000
